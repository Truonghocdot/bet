APP_NAME=gin-core
HTTP_ADDR=:8081
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=10s

DATABASE_URL=postgresql://user:password@localhost:5432/ff789
AUTH_TOKEN_SECRET=dev-secret-change-me
AUTH_TOKEN_TTL=24h
PUBLIC_REGISTER_URL=http://localhost:3000/register

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=2

GATE_BASE_URL=http://localhost:8082
GIN_INTERNAL_TOKEN=change-me
PAYMENT_RECEIVING_ACCOUNTS_REDIS_KEY=shared:payment:receiving-accounts:v1

AUTH_FORGOT_OTP_TTL=5m
AUTH_FORGOT_OTP_COOLDOWN=60s
AUTH_FORGOT_OTP_MAX_ATTEMPTS=5
AUTH_FORGOT_WINDOW=1h
AUTH_FORGOT_LIMIT_IP=5
AUTH_FORGOT_LIMIT_TARGET=3
AUTH_LOGIN_FAIL_WINDOW=15m
AUTH_LOGIN_FAIL_LIMIT_IP=10
AUTH_LOGIN_FAIL_LIMIT_ACCOUNT=5
AUTH_LOGIN_LOCK_DURATION=15m
AUTH_REGISTER_WINDOW=15m
AUTH_REGISTER_LIMIT_IP=5
AUTH_REGISTER_LIMIT_EMAIL=3
AUTH_REGISTER_LIMIT_PHONE=3
